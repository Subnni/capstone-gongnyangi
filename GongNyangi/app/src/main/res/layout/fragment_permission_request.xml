<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#3E4750"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="203dp"
            android:layout_marginStart="24dp"
            android:background="@drawable/cancel_btn_image"
            android:scaleType="fitXY"
            />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:layout_marginBottom="33dp"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:paddingBottom="3dp"
                android:orientation="vertical">
                <TextView
                    android:textColor="#F9F8F9"
                    android:textSize="22sp"
                    android:layout_marginBottom="32dp"
                    android:layout_height="wrap_content"
                    android:layout_width="200dp"
                    android:gravity="center"
                    android:text="사진첩에 접근할 수 \n있도록 허가해주세요!"
                    />
                <TextView
                    android:textColor="#8096AE"
                    android:textSize="15sp"
                    android:layout_marginBottom="32dp"
                    android:layout_height="wrap_content"
                    android:layout_width="251dp"
                    android:gravity="center"
                    android:text="접근 허용 시 사용자의 갤러리에 있는 사진을 공유하고 어쩌구"
                    />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="99dp"
                        android:layout_height="108dp"
                        android:background="@drawable/temp_image"
                        />
                    <TextView
                        android:textColor="#3E4650"
                        android:textSize="12sp"
                        android:layout_marginStart="13dp"
                        android:layout_height="wrap_content"
                        android:layout_width="59dp"
                        android:gravity="center"
                        android:text="접근 허용하기"
                        />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:layout_marginBottom="48dp"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/request_permission_btn_image"
                android:paddingVertical="11dp"
                android:paddingHorizontal="23dp"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical">
                <TextView
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="접근 허용하기"
                    />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
