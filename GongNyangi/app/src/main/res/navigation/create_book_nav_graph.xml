<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:startDestination="@id/GalleryFragment">

    <!--갤러리 -->
    <fragment
        android:id="@+id/GalleryFragment"
        android:name="com.example.gongnyangi.ui.GalleryFragment">
        <action
            android:id="@+id/gotoBookConfirmPhoto"
            app:destination="@id/BookConfirmPhotoFragment" />
    </fragment>

    <!--갤러리> 선택한 사진 확인-->
    <fragment
        android:id="@+id/BookConfirmPhotoFragment"
        android:name="com.example.gongnyangi.ui.BookConfirmPhotoFragment">
        <action
            android:id="@+id/gotoBookLoading"
            app:destination="@id/BookLoadingFragment" />
        <action
            android:id="@+id/gotoGallery"
            app:destination="@id/GalleryFragment" />
    </fragment>

    <!--(개념서)선택한 사진 확인>로딩-->
    <fragment
        android:id="@+id/BookLoadingFragment"
        android:name="com.example.gongnyangi.ui.BookLoadingFragment">
        <action
            android:id="@+id/gotoBookComplete"
            app:destination="@id/BookCompleteFragment" />
    </fragment>
    <!--(개념서)로딩>제작 완료-->
    <fragment
        android:id="@+id/BookCompleteFragment"
        android:name="com.example.gongnyangi.ui.BookCompleteFragment">
    </fragment>

</navigation>